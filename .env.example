# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Setup admin page (opzionale: se non impostato, usa MetodoCantere2026)
SETUP_PASSWORD=1234

# n8n webhook per Analisi Lampo (opzionale: default https://nextstepsrl.app.n8n.cloud/webhook/analisi-lampo)
N8N_WEBHOOK_ANALISI_LAMPO=https://nextstepsrl.app.n8n.cloud/webhook/analisi-lampo

# n8n webhook per Diagnosi Strategica (opzionale: default https://nextstepsrl.app.n8n.cloud/webhook/diagnosi)
N8N_WEBHOOK_DIAGNOSI=https://nextstepsrl.app.n8n.cloud/webhook/diagnosi
